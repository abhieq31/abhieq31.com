---
import Base from '../layouts/Base.astro';
import PostCard from '../components/PostCard.astro';
import { getPublishedPosts, sortPostsNewestFirst } from '../lib/posts';
import { site } from '../config';

const posts = sortPostsNewestFirst(await getPublishedPosts());
---
<Base>
  <div class="container">

    {site.podcastLinks?.length > 0 && (
      <p class="podcast-row">
        <span class="label">Podcast</span>
        {site.podcastLinks.map((l) => <a href={l.href} target={l.href.startsWith('http') ? '_blank' : undefined} rel={l.href.startsWith('http') ? 'noopener' : undefined}>{l.label}</a>)}
      </p>
    )}

    {posts.length === 0 ? (
      <p class="empty-state">First essay coming soon &mdash; <a href="/subscribe">subscribe</a> to get it in your inbox.</p>
    ) : (
      posts.map((post) => <PostCard post={post} />)
    )}

  </div>
</Base>
