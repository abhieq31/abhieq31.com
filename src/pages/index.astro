---
import { getCollection } from "astro:content";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import Card from "@/components/Card.astro";
import Header from "@/components/Header.astro";
import LinkButton from "@/components/LinkButton.astro";
import StructuredData from "@/components/StructuredData.astro";
import { SITE } from "@/config";
import Layout from "@/layouts/Layout.astro";
import getSortedPosts from "@/utils/getSortedPosts";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout description="Technology, software, and business — thinking out loud.">
  <StructuredData type="WebSite" data={{}} />
  <StructuredData type="Person" data={{}} />
  <Header />
  <main id="main-content" data-layout="index">
    {
      featuredPosts.length > 0 && (
        <section id="featured" class="pt-8 pb-2">
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h2" {...data} showImage={false} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-2 pb-6">
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h2" {...data} showImage={false} />
            )}
          </ul>
        </section>
      )
    }

    {
      sortedPosts.length === 0 && (
        <section class="py-16 text-center">
          <p class="text-lg leading-relaxed text-foreground/70">
            No posts yet — check back soon, or{" "}
            <a href="/about" class="text-accent hover:underline">
              learn more about me
            </a>
            .
          </p>
        </section>
      )
    }

    {
      sortedPosts.length > SITE.postPerIndex && (
        <div class="my-8 text-center">
          <LinkButton href="/posts/" class="text-accent hover:underline">
            All Posts
            <IconArrowRight class="inline-block" />
          </LinkButton>
        </div>
      )
    }
  </main>
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
