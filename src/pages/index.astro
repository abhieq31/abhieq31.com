---
import Base from '../layouts/Base.astro';
import PostCard from '../components/PostCard.astro';
import { getPublishedPosts, sortPostsNewestFirst } from '../lib/posts';
import { site } from '../config';

const posts = sortPostsNewestFirst(await getPublishedPosts());
---
<Base>
  <div class="container">
    {site.podcastLinks?.length > 0 && (
      <p class="podcast-row">
        <span class="label">Podcast</span>
        {site.podcastLinks.map((l) => <a href={l.href}>{l.label}</a>)}
      </p>
    )}

    {posts.length === 0 ? (
      <p class="empty">No posts yet. Add a Markdown file in <code>src/content/posts/</code>.</p>
    ) : (
      posts.map((post) => <PostCard post={post} />)
    )}
  </div>
</Base>
