---
import Base from '../../layouts/Base.astro';
import AudioPlayer from '../../components/AudioPlayer.astro';
import { getPublishedPosts, sortPostsNewestFirst } from '../../lib/posts';
import { formatDate } from '../../utils';
import { site } from '../../config';
import { getEntry, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = sortPostsNewestFirst(await getPublishedPosts());
  return posts.map((post) => ({
    params: { slug: post.id },
    props: {
      post,
      related: posts.filter((c) => c.id !== post.id).slice(0, 3),
    },
  }));
}

const { post, related = [] } = Astro.props;
const entry = await getEntry('posts', post.id);
const { Content } = await render(entry!);

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.title,
  description: post.subtitle || site.description,
  datePublished: post.date.toISOString(),
  author: { '@type': 'Person', name: site.author },
  url: new URL(`/posts/${post.id}/`, Astro.site).href,
  mainEntityOfPage: new URL(`/posts/${post.id}/`, Astro.site).href,
};
---
<Base title={post.title} description={post.subtitle} type="article" publishedTime={post.date.toISOString()}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
  <article class="container article-container">
    <p class="article-date">
      {formatDate(post.date)}{!post.audio && ` · ${post.readingMinutes} min read`}
    </p>
    <h1 class="article-title">{post.title}</h1>
    {post.subtitle && <p class="article-subtitle">{post.subtitle}</p>}

    {post.audio && (
      <div class="article-audio">
        <AudioPlayer audio={post.audio} duration={post.duration} />
      </div>
    )}

    <div class="article-body"><Content /></div>

    {related.length > 0 && (
      <aside class="related-posts" aria-labelledby="related-title">
        <h2 id="related-title">Related</h2>
        <div class="related-grid">
          {related.map((item) => (
            <a href={`/posts/${item.id}/`}>
              <span>{item.title}</span>
              <time>{formatDate(item.date)}</time>
            </a>
          ))}
        </div>
      </aside>
    )}

    <a class="back-link" href="/archive">← Archive</a>
  </article>
</Base>
