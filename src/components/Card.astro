---
import type { CollectionEntry } from "astro:content";
import { getPath } from "@/utils/getPath";
import { slugifyStr } from "@/utils/slugify";

export interface Props extends CollectionEntry<"blog"> {
  variant?: "h2" | "h3";
  showImage?: boolean;
}

const { variant = "h2", data, id, filePath, body } = Astro.props;
const { title, subtitle, description, pubDatetime } = data;
const path = getPath(id, filePath);
const date = pubDatetime.toLocaleDateString("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
});
const titleStyle = { viewTransitionName: slugifyStr(title) };

// Excerpt like nav.al: use the description, else auto-derive from the post body.
const raw = (description?.trim() || body || "")
  .replace(/!\[[^\]]*\]\([^)]*\)/g, "") // images
  .replace(/\[([^\]]*)\]\([^)]*\)/g, "$1") // links → text
  .replace(/[#>*_`~]/g, "") // markdown syntax
  .replace(/\s+/g, " ")
  .trim();
const excerpt = raw.length > 200 ? `${raw.slice(0, 200).replace(/\s+\S*$/, "")}…` : raw;

const headingClass =
  "text-2xl font-bold leading-tight tracking-tight text-foreground transition-colors group-hover:text-accent sm:text-3xl";
---

<li class="mb-12">
  <a href={path} class="group block">
    {
      variant === "h2" ? (
        <h2 class={headingClass} style={titleStyle}>
          {title}
        </h2>
      ) : (
        <h3 class={headingClass} style={titleStyle}>
          {title}
        </h3>
      )
    }
  </a>
  {subtitle && <p class="mt-1 text-lg text-foreground/85">{subtitle}</p>}
  {
    excerpt && (
      <p class="mt-2 text-[1.05rem] leading-relaxed text-foreground/65">
        {excerpt}{" "}
        <a href={path} class="font-medium whitespace-nowrap text-accent hover:underline">
          More ›
        </a>
      </p>
    )
  }
  <div class="mt-3 text-sm text-muted">{date}</div>
</li>
