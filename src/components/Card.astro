---
import type { CollectionEntry } from "astro:content";
import { getPath } from "@/utils/getPath";
import { slugifyStr } from "@/utils/slugify";

export interface Props extends CollectionEntry<"blog"> {
  variant?: "h2" | "h3";
  showImage?: boolean;
}

const { variant = "h2", data, id, filePath } = Astro.props;
const { title, description, pubDatetime } = data;
const path = getPath(id, filePath);
const date = pubDatetime.toLocaleDateString("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
});
const titleStyle = { viewTransitionName: slugifyStr(title) };
---

<li class="border-b border-border">
  <a href={path} class="flex gap-3 px-2 py-4 transition-colors hover:bg-foreground/[0.03]">
    <img
      src="/favicon.svg"
      alt="Abhi"
      width="44"
      height="44"
      class="size-11 shrink-0 rounded-full border border-border bg-foreground/5 p-2.5"
    />
    <div class="min-w-0 flex-1">
      <div class="flex flex-wrap items-center gap-x-1 text-[15px] leading-5">
        <span class="font-bold text-foreground">Abhi</span>
        <span class="text-muted">@abhieq31</span>
        <span class="text-muted">·</span>
        <span class="text-muted">{date}</span>
      </div>
      {
        variant === "h2" ? (
          <h2 class="mt-1 text-lg font-bold leading-snug text-foreground" style={titleStyle}>
            {title}
          </h2>
        ) : (
          <h3 class="mt-1 text-lg font-bold leading-snug text-foreground" style={titleStyle}>
            {title}
          </h3>
        )
      }
      {
        description && (
          <p class="mt-1 text-[15px] leading-normal text-foreground/75">{description}</p>
        )
      }
    </div>
  </a>
</li>
