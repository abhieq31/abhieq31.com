---
import { site } from '../config';
const path = Astro.url.pathname;
const isActive = (href: string) => href !== '/' && path.startsWith(href);
const action = site.newsletter?.action || '/subscribe';
---
<header class="site-header" id="site-header">
  <a class="brand" href="/">{site.name}</a>

  <button
    class="menu-toggle"
    id="menu-toggle"
    type="button"
    aria-label="Open menu"
    aria-controls="header-actions"
    aria-expanded="false"
  >
    <span></span>
    <span></span>
  </button>

  <div class="header-actions" id="header-actions">
    <nav class="nav" id="nav-default" aria-label="Primary navigation">
      <a href="/archive" class={isActive('/archive') ? 'active' : ''}>Archive</a>
      <a href={site.socials.x} target="_blank" rel="me noopener"><span class="desktop-label">X</span><span class="mobile-label">Twitter</span></a>
      <a href={site.socials.instagram} target="_blank" rel="me noopener">Instagram</a>
      <button class="nav-subscribe-btn" id="subscribe-open" type="button" aria-label="Open subscribe form">
        Subscribe
      </button>
    </nav>

    <form
      class="nav-subscribe-form"
      id="nav-subscribe-form"
      action={action}
      method="post"
      target="_blank"
      aria-hidden="true"
    >
      <input
        type="email"
        name="email"
        placeholder="Email"
        required
        aria-label="Email address"
        autocomplete="email"
        tabindex="-1"
      />
      <button type="submit" tabindex="-1">Subscribe</button>
      <button type="button" id="subscribe-cancel" class="cancel" tabindex="-1">Cancel</button>
    </form>
  </div>
</header>

<script>
  const siteHeader = document.getElementById('site-header') as HTMLElement | null;
  const menuBtn = document.getElementById('menu-toggle') as HTMLButtonElement | null;
  const openBtn = document.getElementById('subscribe-open') as HTMLButtonElement | null;
  const cancelBtn = document.getElementById('subscribe-cancel') as HTMLButtonElement | null;
  const headerActions = document.getElementById('header-actions') as HTMLElement | null;
  const navDefault = document.getElementById('nav-default') as HTMLElement | null;
  const subForm = document.getElementById('nav-subscribe-form') as HTMLFormElement | null;
  const formControls = subForm?.querySelectorAll<HTMLInputElement | HTMLButtonElement>('input, button');
  const desktopMedia = window.matchMedia('(min-width: 721px)');

  function setFormTabIndex(value: 0 | -1) {
    formControls?.forEach((control) => {
      control.tabIndex = value;
    });
  }

  function isMobileMenu() {
    return !desktopMedia.matches;
  }

  function syncMobileForm() {
    if (isMobileMenu() && siteHeader?.classList.contains('is-menu-open')) {
      subForm?.setAttribute('aria-hidden', 'false');
      setFormTabIndex(0);
      return;
    }

    if (!headerActions?.classList.contains('is-subscribing')) {
      subForm?.setAttribute('aria-hidden', 'true');
      setFormTabIndex(-1);
    }
  }

  function openSubscribe() {
    headerActions?.classList.add('is-subscribing');
    navDefault?.setAttribute('aria-hidden', 'true');
    subForm?.setAttribute('aria-hidden', 'false');
    setFormTabIndex(0);
    window.setTimeout(() => {
      subForm?.querySelector<HTMLInputElement>('input[type=email]')?.focus();
    }, 220);
  }

  function closeSubscribe({ restoreFocus = true } = {}) {
    headerActions?.classList.remove('is-subscribing');
    navDefault?.setAttribute('aria-hidden', 'false');
    syncMobileForm();
    if (restoreFocus) openBtn?.focus();
  }

  function openMenu() {
    siteHeader?.classList.add('is-menu-open');
    document.documentElement.classList.add('menu-lock');
    menuBtn?.setAttribute('aria-expanded', 'true');
    menuBtn?.setAttribute('aria-label', 'Close menu');
    navDefault?.setAttribute('aria-hidden', 'false');
    syncMobileForm();
  }

  function closeMenu() {
    siteHeader?.classList.remove('is-menu-open');
    document.documentElement.classList.remove('menu-lock');
    menuBtn?.setAttribute('aria-expanded', 'false');
    menuBtn?.setAttribute('aria-label', 'Open menu');
    syncMobileForm();
  }

  openBtn?.addEventListener('click', openSubscribe);
  cancelBtn?.addEventListener('click', () => closeSubscribe());
  menuBtn?.addEventListener('click', () => {
    if (siteHeader?.classList.contains('is-menu-open')) closeMenu();
    else openMenu();
  });

  desktopMedia.addEventListener('change', () => {
    closeMenu();
    closeSubscribe({ restoreFocus: false });
  });

  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape') return;
    if (siteHeader?.classList.contains('is-menu-open')) closeMenu();
    else if (headerActions?.classList.contains('is-subscribing')) closeSubscribe();
  });
</script>
