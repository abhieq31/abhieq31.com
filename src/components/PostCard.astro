---
import type { Post } from '../lib/posts';
import { formatDate } from '../utils';
import AudioPlayer from './AudioPlayer.astro';

interface Props {
  post: Post;
}
const { post } = Astro.props;
const url = `/posts/${post.id}/`;
---
<article class="post">
  <h2 class="post-title"><a href={url}>{post.title}</a></h2>
  {post.subtitle && <p class="post-subtitle">{post.subtitle}</p>}
  {post.excerpt && (
    <p class="post-excerpt">{post.excerpt} <a class="more" href={url}>More &rsaquo;</a></p>
  )}
  {post.audio ? (
    <AudioPlayer audio={post.audio} duration={post.duration} date={formatDate(post.date)} />
  ) : (
    <div class="meta"><span>{formatDate(post.date)}</span></div>
  )}
</article>
