---
import { site } from '../config';
interface Props {
  audio: string;
  duration?: string;
  date?: string;
}
const { audio, duration, date } = Astro.props;
// Unique id so each player controls only its own <audio> element.
const id = 'audio-' + Math.random().toString(36).slice(2, 9);
---
<div class="meta">
  <button class="play-btn" data-audio={id} aria-label="Play episode">
    <span class="play"><svg viewBox="0 0 24 24" width="11" height="11" fill="currentColor"><path d="M8 5v14l11-7z" /></svg></span>
    <span class="pause"><svg viewBox="0 0 24 24" width="11" height="11" fill="currentColor"><path d="M6 5h4v14H6zM14 5h4v14h-4z" /></svg></span>
  </button>
  <audio id={id} src={audio} preload="none"></audio>
  {duration && <span class="duration">{duration}</span>}
  <details class="dropdown">
    <summary>Get podcast ⌄</summary>
    <div class="menu">
      {site.podcastLinks.map((l) => <a href={l.href}>{l.label}</a>)}
      <a class="download" href={audio} download>Download</a>
    </div>
  </details>
  {date && <span>{date}</span>}
</div>

<script>
  // Bind every play button once. Pauses other audio when one starts; the
  // play/pause icon stays in sync via the audio element's own events.
  document.querySelectorAll<HTMLButtonElement>('.play-btn').forEach((btn) => {
    if (btn.dataset.bound) return;
    btn.dataset.bound = '1';
    const audio = document.getElementById(btn.dataset.audio || '') as HTMLAudioElement | null;
    if (!audio) return;
    btn.addEventListener('click', () => {
      if (audio.paused) {
        document.querySelectorAll('audio').forEach((a) => { if (a !== audio) a.pause(); });
        audio.play();
      } else {
        audio.pause();
      }
    });
    audio.addEventListener('play', () => {
      btn.classList.add('playing');
      btn.setAttribute('aria-label', 'Pause episode');
    });
    const reset = () => {
      btn.classList.remove('playing');
      btn.setAttribute('aria-label', 'Play episode');
    };
    audio.addEventListener('pause', reset);
    audio.addEventListener('ended', reset);
  });
</script>
